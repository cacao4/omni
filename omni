--// Replace your current CreateWindow theme logic with this updated version
function Omni:CreateWindow(title, keybind)
    local Main = Instance.new("Frame", self.Gui)
    Main.Size = UDim2.fromOffset(520, 400); Main.Position = UDim2.new(0.5, -260, 0.5, -200)
    Main.BackgroundColor3 = Color3.fromRGB(240, 242, 245) -- Main background
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 14)

    local Topbar = Instance.new("Frame", Main)
    Topbar.Size = UDim2.new(1, -24, 0, 35); Topbar.Position = UDim2.fromOffset(12, 12)
    Topbar.BackgroundColor3 = self.ThemeColor
    Instance.new("UICorner", Topbar).CornerRadius = UDim.new(0, 10)

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(0, 380, 0, 325); Container.Position = UDim2.fromOffset(12, 60)
    Container.BackgroundColor3 = Color3.fromRGB(225, 228, 232)
    Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 10)

    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 104, 0, 325); Sidebar.Position = UDim2.fromOffset(404, 60)
    Sidebar.BackgroundColor3 = Color3.fromRGB(225, 228, 232)
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 10)

    --// NEW THEME SYSTEM: Add everything to the list
    self.ElementsToTheme = {
        ["Accents"] = {Topbar}, -- Primary color
        ["Containers"] = {Container, Sidebar} -- Subtle tint
    }

    --// Function to apply the theme to EVERYTHING
    local function ApplyTheme(color)
        -- Animate the Topbar (Accent)
        for _, obj in pairs(self.ElementsToTheme["Accents"]) do
            TweenService:Create(obj, TweenInfo.new(0.4), {BackgroundColor3 = color}):Play()
        end
        
        -- Animate the background containers (Subtle tint)
        local h, s, v = color:ToHSV()
        local tintColor = Color3.fromHSV(h, s * 0.15, v * 0.9) -- Makes a light version of the theme
        
        for _, obj in pairs(self.ElementsToTheme["Containers"]) do
            TweenService:Create(obj, TweenInfo.new(0.4), {BackgroundColor3 = tintColor}):Play()
        end
    end

    --// Update the Settings buttons to use the new ApplyTheme function
    local SetTab = Lib:CreateTab("settings")
    for name, color in pairs(Themes) do
        SetTab:Button(name, function()
            ApplyTheme(color)
            UI:Notify("theme", "switched to " .. name, 2)
        end)
    end
    
    -- Rest of your window logic (Dragging, Tabs, etc)
    return Lib
end
