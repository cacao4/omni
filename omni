local Omni = {}
Omni.__index = Omni

local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

function Omni.new()
    local self = setmetatable({}, Omni)
    if CoreGui:FindFirstChild("Omni_UI") then CoreGui.Omni_UI:Destroy() end
    
    self.Gui = Instance.new("ScreenGui", CoreGui)
    self.Gui.Name = "Omni_UI"
    self.FirstTab = nil

    self.NotifContainer = Instance.new("Frame", self.Gui)
    self.NotifContainer.Size = UDim2.new(0, 250, 1, 0)
    self.NotifContainer.Position = UDim2.new(1, -260, 0, 0)
    self.NotifContainer.BackgroundTransparency = 1
    local Layout = Instance.new("UIListLayout", self.NotifContainer)
    Layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    Layout.Padding = UDim.new(0, 10)
    
    -- Start 5-Minute Notification Loop
    task.spawn(function()
        while task.wait(300) do
            self:Notify("enjoying ui?", "you can get it on rscripts", 5)
        end
    end)
    
    return self
end

function Omni:ShowLoading(scriptName)
    local LoadFrame = Instance.new("Frame", self.Gui)
    LoadFrame.Size = UDim2.new(1, 0, 1, 0)
    LoadFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    LoadFrame.ZIndex = 100 -- Covers everything
    
    local BigTitle = Instance.new("TextLabel", LoadFrame)
    BigTitle.Size = UDim2.new(1, 0, 0, 100)
    BigTitle.Position = UDim2.new(0, 0, 0.45, 0)
    BigTitle.Text = scriptName:lower()
    BigTitle.Font = Enum.Font.GothamBold
    BigTitle.TextColor3 = Color3.new(1, 1, 1)
    BigTitle.TextSize = 60
    BigTitle.BackgroundTransparency = 1
    
    local CornerCredit = Instance.new("TextLabel", LoadFrame)
    CornerCredit.Size = UDim2.new(0, 200, 0, 30)
    CornerCredit.Position = UDim2.new(1, -210, 1, -40)
    CornerCredit.Text = "omni ui"
    CornerCredit.Font = Enum.Font.GothamMedium
    CornerCredit.TextColor3 = Color3.fromRGB(150, 150, 150)
    CornerCredit.TextSize = 18
    CornerCredit.TextXAlignment = 2
    CornerCredit.BackgroundTransparency = 1

    task.wait(3)
    TweenService:Create(LoadFrame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
    TweenService:Create(BigTitle, TweenInfo.new(1), {TextTransparency = 1}):Play()
    TweenService:Create(CornerCredit, TweenInfo.new(1), {TextTransparency = 1}):Play()
    task.delay(1, function() LoadFrame:Destroy() end)
end

function Omni:Notify(title, text, duration)
    local n = Instance.new("Frame", self.NotifContainer)
    n.Size = UDim2.new(1, 0, 0, 60)
    n.BackgroundColor3 = Color3.new(0,0,0)
    n.BackgroundTransparency = 0.5 -- Transparent as requested
    n.Position = UDim2.new(1.5, 0, 0, 0)
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    

    local t = Instance.new("TextLabel", n)
    t.Size = UDim2.new(1, -20, 0, 20); t.Position = UDim2.fromOffset(10, 8)
    t.Text = title:lower(); t.Font = Enum.Font.GothamBold; t.TextColor3 = Color3.new(1,1,1)
    t.TextSize = 13; t.BackgroundTransparency = 1; t.TextXAlignment = 0
    
    local d = Instance.new("TextLabel", n)
    d.Size = UDim2.new(1, -20, 0, 20); d.Position = UDim2.fromOffset(10, 28)
    d.Text = text:lower(); d.Font = Enum.Font.Gotham; d.TextColor3 = Color3.fromRGB(200, 200, 200)
    d.TextSize = 12; d.BackgroundTransparency = 1; d.TextXAlignment = 0

    TweenService:Create(n, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    task.delay(duration or 3, function()
        if n and n.Parent then
            TweenService:Create(n, TweenInfo.new(0.4), {Position = UDim2.new(1.5, 0, 0, 0)}):Play()
            task.wait(0.5); n:Destroy()
        end
    end)
end

