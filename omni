local Omni = {}
Omni.__index = Omni

local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

function Omni.new()
    local self = setmetatable({}, Omni)
    if CoreGui:FindFirstChild("Omni_UI") then CoreGui.Omni_UI:Destroy() end
    self.Gui = Instance.new("ScreenGui", CoreGui)
    self.Gui.Name = "Omni_UI"
    self.FirstTab = nil
    self.Enabled = true
    
    -- High-End Notification System
    self.NotifContainer = Instance.new("Frame", self.Gui)
    self.NotifContainer.Size = UDim2.new(0, 260, 1, 0)
    self.NotifContainer.Position = UDim2.new(1, -270, 0, 0)
    self.NotifContainer.BackgroundTransparency = 1
    local Layout = Instance.new("UIListLayout", self.NotifContainer)
    Layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    Layout.Padding = UDim.new(0, 8)
    Instance.new("UIPadding", self.NotifContainer).PaddingBottom = UDim.new(0, 20)
    
    return self
end

function Omni:Notify(title, text, duration)
    local n = Instance.new("Frame", self.NotifContainer)
    n.Size = UDim2.new(1, 0, 0, 65)
    n.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    n.Position = UDim2.new(1.5, 0, 0, 0)
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 12)
    local s = Instance.new("UIStroke", n); s.Color = Color3.fromRGB(0, 0, 0); s.Transparency = 0.9

    local t = Instance.new("TextLabel", n)
    t.Size = UDim2.new(1, -20, 0, 25); t.Position = UDim2.fromOffset(12, 10)
    t.Text = title:lower(); t.Font = Enum.Font.GothamBold; t.TextColor3 = Color3.fromRGB(40, 45, 50); t.TextSize = 13; t.BackgroundTransparency = 1; t.TextXAlignment = 0
    
    local d = Instance.new("TextLabel", n)
    d.Size = UDim2.new(1, -20, 0, 20); d.Position = UDim2.fromOffset(12, 32)
    d.Text = text:lower(); d.Font = Enum.Font.Gotham; d.TextColor3 = Color3.fromRGB(120, 125, 130); d.TextSize = 12; d.BackgroundTransparency = 1; d.TextXAlignment = 0

    TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    task.delay(duration or 3, function()
        if n and n.Parent then
            TweenService:Create(n, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(1.6, 0, 0, 0)}):Play()
            task.wait(0.5); n:Destroy()
        end
    end)
end

function Omni:CreateWindow(title, keybind)
    local Main = Instance.new("Frame", self.Gui)
    Main.Size = UDim2.fromOffset(520, 400); Main.Position = UDim2.new(0.5, -260, 0.5, -200)
    Main.BackgroundColor3 = Color3.fromRGB(242, 244, 247); Main.Active = true; Main.ClipsDescendants = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 16)

    local Topbar = Instance.new("Frame", Main)
    Topbar.Size = UDim2.new(1, -24, 0, 38); Topbar.Position = UDim2.fromOffset(12, 12)
    Topbar.BackgroundColor3 = Color3.fromRGB(160, 210, 255); Instance.new("UICorner", Topbar).CornerRadius = UDim.new(0, 12)

    local TitleLabel = Instance.new("TextLabel", Topbar)
    TitleLabel.Size = UDim2.new(1, 0, 1, 0); TitleLabel.Position = UDim2.fromOffset(15, 0)
    TitleLabel.Text = title:lower(); TitleLabel.Font = Enum.Font.GothamMedium; TitleLabel.TextColor3 = Color3.fromRGB(60, 70, 80); TitleLabel.TextSize = 14; TitleLabel.TextXAlignment = 0; TitleLabel.BackgroundTransparency = 1

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(0, 380, 0, 325); Container.Position = UDim2.fromOffset(12, 62)
    Container.BackgroundColor3 = Color3.fromRGB(230, 233, 238); Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 12)

    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 104, 0, 325); Sidebar.Position = UDim2.fromOffset(404, 62)
    Sidebar.BackgroundColor3 = Color3.fromRGB(230, 233, 238); Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 12)

    -- Smooth Dragging & Toggle
    local dragStart, startPos
    Topbar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragStart = input.Position; startPos = Main.Position end end)
    UIS.InputChanged:Connect(function(input) if dragStart and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragStart = nil end end)

    UIS.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == (keybind or Enum.KeyCode.F6) then
            self.Enabled = not self.Enabled
            TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Size = self.Enabled and UDim2.fromOffset(520, 400) or UDim2.fromOffset(520, 0)}):Play()
        end
    end)

    local Pages = {}
    local Lib = {}

    function Lib:CreateTab(name)
        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, -20, 1, -20); Page.Position = UDim2.fromOffset(10, 10); Page.BackgroundTransparency = 1; Page.Visible = false; Page.ScrollBarThickness = 0; Page.AutomaticCanvasSize = "Y"
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 10)
        
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0, 85, 0, 35); TabBtn.BackgroundColor3 = Color3.fromRGB(210, 215, 220); TabBtn.Text = name:lower(); TabBtn.Font = Enum.Font.Gotham; TabBtn.TextColor3 = Color3.fromRGB(80, 85, 90)
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 10)
        
        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Pages) do v.Visible = false end
            Page.Visible = true
        end)

        if not self.FirstTab then self.FirstTab = Page; Page.Visible = true end
        Pages[name] = Page
        
        local PageElements = {}

        function PageElements:Toggle(text, default, cb)
            local TFrame = Instance.new("Frame", Page)
            TFrame.Size = UDim2.new(1, 0, 0, 42); TFrame.BackgroundColor3 = Color3.fromRGB(220, 225, 230); Instance.new("UICorner", TFrame).CornerRadius = UDim.new(0, 10)
            
            local TText = Instance.new("TextLabel", TFrame)
            TText.Size = UDim2.new(1, -60, 1, 0); TText.Position = UDim2.fromOffset(12, 0); TText.Text = text:lower(); TText.Font = Enum.Font.Gotham; TText.TextColor3 = Color3.fromRGB(60, 60, 60); TText.TextSize = 13; TText.BackgroundTransparency = 1; TText.TextXAlignment = 0

            local TButton = Instance.new("TextButton", TFrame)
            TButton.Size = UDim2.fromOffset(32, 20); TButton.Position = UDim2.new(1, -45, 0.5, -10); TButton.BackgroundColor3 = default and Color3.fromRGB(160, 210, 255) or Color3.fromRGB(180, 185, 190); TButton.Text = ""
            Instance.new("UICorner", TButton).CornerRadius = UDim.new(1, 0)

            local state = default
            TButton.MouseButton1Click:Connect(function()
                state = not state
                TweenService:Create(TButton, TweenInfo.new(0.25), {BackgroundColor3 = state and Color3.fromRGB(160, 210, 255) or Color3.fromRGB(180, 185, 190)}):Play()
                cb(state)
            end)
        end

        function PageElements:Button(text, cb)
            local B = Instance.new("TextButton", Page)
            B.Size = UDim2.new(1, 0, 0, 42); B.BackgroundColor3 = Color3.fromRGB(220, 225, 230); B.Text = text:lower(); B.Font = Enum.Font.Gotham; B.TextColor3 = Color3.fromRGB(60, 60, 60); B.TextSize = 13; Instance.new("UICorner", B).CornerRadius = UDim.new(0, 10)
            B.MouseButton1Click:Connect(cb)
        end

        return PageElements
    end
    return Lib
end

return Omni
