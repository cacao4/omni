local Omni = {}
Omni.__index = Omni

local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

function Omni.new()
    local self = setmetatable({}, Omni)
    if CoreGui:FindFirstChild("Omni_UI") then CoreGui.Omni_UI:Destroy() end
    
    self.Gui = Instance.new("ScreenGui", CoreGui)
    self.Gui.Name = "Omni_UI"
    return self
end

function Omni:CreateWindow(title)
    local Main = Instance.new("Frame", self.Gui)
    Main.Size = UDim2.fromOffset(520, 380)
    Main.Position = UDim2.new(0.5, -260, 0.5, -190)
    Main.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)

    local Topbar = Instance.new("Frame", Main)
    Topbar.Size = UDim2.new(1, -24, 0, 32)
    Topbar.Position = UDim2.fromOffset(12, 12)
    Topbar.BackgroundColor3 = Color3.fromRGB(210, 215, 218)
    Instance.new("UICorner", Topbar).CornerRadius = UDim.new(0, 8)

    local TitleLabel = Instance.new("TextLabel", Topbar)
    TitleLabel.Size = UDim2.new(1, -12, 1, 0)
    TitleLabel.Position = UDim2.fromOffset(12, 0)
    TitleLabel.Text = title; TitleLabel.Font = Enum.Font.Gotham; TitleLabel.TextColor3 = Color3.fromRGB(50, 55, 60); TitleLabel.TextSize = 14; TitleLabel.TextXAlignment = 0; TitleLabel.BackgroundTransparency = 1

    local dragging, dragStart, startPos
    Topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = Main.Position end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(0, 380, 0, 310); Container.Position = UDim2.fromOffset(12, 56); Container.BackgroundColor3 = Color3.fromRGB(225, 228, 230)
    Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 12)

    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 104, 0, 310); Sidebar.Position = UDim2.fromOffset(404, 56); Sidebar.BackgroundColor3 = Color3.fromRGB(225, 228, 230)
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 12)
    Instance.new("UIListLayout", Sidebar).HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 15)

    local Pages = {}
    local Lib = {}

    function Lib:CreateTab(name)
        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, -10, 1, -10); Page.Position = UDim2.fromOffset(5, 5); Page.BackgroundTransparency = 1; Page.Visible = false; Page.ScrollBarThickness = 2; Page.CanvasSize = UDim2.new(0,0,0,0); Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        local Layout = Instance.new("UIListLayout", Page); Layout.Padding = UDim.new(0, 8); Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        Instance.new("UIPadding", Page).PaddingTop = UDim.new(0, 5)

        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0, 85, 0, 40); TabBtn.BackgroundColor3 = Color3.fromRGB(205, 210, 212); TabBtn.Text = name:lower(); TabBtn.Font = Enum.Font.Gotham; TabBtn.TextColor3 = Color3.fromRGB(50, 55, 60)
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 20)
        
        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Pages) do v.Visible = false end
            Page.Visible = true
        end)
        if #Sidebar:GetChildren() == 2 then Page.Visible = true end
        Pages[name] = Page

        local PageElements = {}

        function PageElements:Button(text, cb)
            local B = Instance.new("TextButton", Page)
            B.Size = UDim2.new(0, 340, 0, 35); B.BackgroundColor3 = Color3.fromRGB(210, 215, 218); B.Text = text:lower(); B.Font = Enum.Font.Gotham; B.TextColor3 = Color3.fromRGB(60, 60, 60); B.TextSize = 13
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)
            B.MouseButton1Click:Connect(cb)
        end

        function PageElements:Slider(text, min, max, default, cb)
            local SFrame = Instance.new("Frame", Page)
            SFrame.Size = UDim2.new(0, 340, 0, 45); SFrame.BackgroundColor3 = Color3.fromRGB(210, 215, 218)
            Instance.new("UICorner", SFrame).CornerRadius = UDim.new(0, 8)
            
            local Title = Instance.new("TextLabel", SFrame)
            Title.Position = UDim2.new(0, 10, 0, 5); Title.Text = text:lower(); Title.Font = Enum.Font.Gotham; Title.TextColor3 = Color3.fromRGB(60, 60, 60); Title.TextSize = 12; Title.BackgroundTransparency = 1
            
            local Bar = Instance.new("Frame", SFrame)
            Bar.Size = UDim2.new(0, 320, 0, 6); Bar.Position = UDim2.new(0, 10, 0, 28); Bar.BackgroundColor3 = Color3.fromRGB(190, 195, 198)
            
            local Fill = Instance.new("Frame", Bar)
            Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0); Fill.BackgroundColor3 = Color3.fromRGB(120, 130, 140)

            local function update(input)
                local pos = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                Fill.Size = UDim2.new(pos, 0, 1, 0)
                cb(math.floor(min + (max - min) * pos))
            end

            Bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local connection; connection = UIS.InputChanged:Connect(function(move)
                        if UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then update(move) else connection:Disconnect() end
                    end)
                    update(input)
                end
            end)
        end

        function PageElements:Dropdown(text, list, cb)
            local DFrame = Instance.new("Frame", Page)
            DFrame.Size = UDim2.new(0, 340, 0, 35); DFrame.BackgroundColor3 = Color3.fromRGB(210, 215, 218); DFrame.ClipsDescendants = true
            Instance.new("UICorner", DFrame).CornerRadius = UDim.new(0, 8)
            
            local DBtn = Instance.new("TextButton", DFrame)
            DBtn.Size = UDim2.new(1, 0, 0, 35); DBtn.BackgroundTransparency = 1; DBtn.Text = text:lower() .. "  ▼"; DBtn.Font = Enum.Font.Gotham; DBtn.TextColor3 = Color3.fromRGB(60, 60, 60)
            
            local open = false
            DBtn.MouseButton1Click:Connect(function()
                open = not open
                DFrame.Size = open and UDim2.new(0, 340, 0, 35 + (#list * 30)) or UDim2.new(0, 340, 0, 35)
            end)

            for _, val in pairs(list) do
                local opt = Instance.new("TextButton", DFrame)
                opt.Size = UDim2.new(1, 0, 0, 30); opt.Position = UDim2.new(0, 0, 0, 35 + ((_ - 1) * 30)); opt.Text = tostring(val); opt.BackgroundColor3 = Color3.fromRGB(200, 205, 208); opt.Font = Enum.Font.Gotham; opt.TextSize = 12
                opt.MouseButton1Click:Connect(function()
                    DBtn.Text = text:lower() .. ": " .. tostring(val)
                    cb(val)
                    open = false; DFrame.Size = UDim2.new(0, 340, 0, 35)
                end)
            end
        end

        return PageElements
    end
    return Lib
end

return Omni
