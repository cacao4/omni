local Omni = {}
Omni.__index = Omni

local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

function Omni.new()
    local self = setmetatable({}, Omni)
    if CoreGui:FindFirstChild("Omni_UI") then CoreGui.Omni_UI:Destroy() end
    self.Gui = Instance.new("ScreenGui", CoreGui)
    self.Gui.Name = "Omni_UI"
    self.FirstTab = nil
    self.Enabled = true
    
    -- Notification System (Stacking)
    self.NotifContainer = Instance.new("Frame", self.Gui)
    self.NotifContainer.Size = UDim2.new(0, 250, 1, 0)
    self.NotifContainer.Position = UDim2.new(1, -260, 0, 0)
    self.NotifContainer.BackgroundTransparency = 1
    local Layout = Instance.new("UIListLayout", self.NotifContainer)
    Layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    Layout.Padding = UDim.new(0, 10)
    Instance.new("UIPadding", self.NotifContainer).PaddingBottom = UDim.new(0, 20)
    
    return self
end

function Omni:Notify(title, text, duration)
    local n = Instance.new("Frame", self.NotifContainer)
    n.Size = UDim2.new(1, 0, 0, 65)
    n.BackgroundColor3 = Color3.fromRGB(140, 50, 230) -- Legacy Purple
    n.Position = UDim2.new(1.5, 0, 0, 0)
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    local s = Instance.new("UIStroke", n); s.Color = Color3.new(1,1,1); s.Transparency = 0.8
    
    local t = Instance.new("TextLabel", n)
    t.Size = UDim2.new(1, -20, 0, 25); t.Position = UDim2.fromOffset(12, 8)
    t.Text = title:upper(); t.Font = Enum.Font.GothamBold; t.TextColor3 = Color3.new(1,1,1); t.TextSize = 13; t.BackgroundTransparency = 1; t.TextXAlignment = 0
    
    local d = Instance.new("TextLabel", n)
    d.Size = UDim2.new(1, -20, 0, 20); d.Position = UDim2.fromOffset(12, 32)
    d.Text = text:lower(); d.Font = Enum.Font.Gotham; d.TextColor3 = Color3.fromRGB(220,220,220); d.TextSize = 12; d.BackgroundTransparency = 1; d.TextXAlignment = 0

    TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    task.delay(duration or 3, function()
        if n and n.Parent then
            TweenService:Create(n, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(1.6, 0, 0, 0)}):Play()
            task.wait(0.5); n:Destroy()
        end
    end)
end

function Omni:CreateWindow(title, keybind)
    local Main = Instance.new("Frame", self.Gui)
    Main.Size = UDim2.fromOffset(520, 400); Main.Position = UDim2.new(0.5, -260, 0.5, -200)
    Main.BackgroundColor3 = Color3.fromRGB(140, 50, 230); Main.Active = true; Main.ClipsDescendants = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 16)

    local RedBar = Instance.new("Frame", Main)
    RedBar.Size = UDim2.new(1, 0, 0, 40); RedBar.Position = UDim2.fromOffset(0, 45)
    RedBar.BackgroundColor3 = Color3.fromRGB(255, 30, 0); RedBar.BorderSizePixel = 0

    local TitleLabel = Instance.new("TextLabel", RedBar)
    TitleLabel.Size = UDim2.new(1, 0, 1, 0); TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = title:upper(); TitleLabel.Font = Enum.Font.GothamBold; TitleLabel.TextColor3 = Color3.new(1,1,1); TitleLabel.TextSize = 14

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(0, 380, 0, 270); Container.Position = UDim2.fromOffset(12, 95)
    Container.BackgroundColor3 = Color3.fromRGB(0,0,0); Container.BackgroundTransparency = 0.3
    Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 12)

    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 105, 0, 270); Sidebar.Position = UDim2.fromOffset(403, 95)
    Sidebar.BackgroundColor3 = Color3.fromRGB(0,0,0); Sidebar.BackgroundTransparency = 0.3
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 12)

    -- Draggable Logic (Smooth)
    local dragStart, startPos
    Main.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragStart = input.Position; startPos = Main.Position end end)
    UIS.InputChanged:Connect(function(input) if dragStart and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        TweenService:Create(Main, TweenInfo.new(0.15, Enum.EasingStyle.Quart), {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}):Play()
    end end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragStart = nil end end)

    UIS.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == (keybind or Enum.KeyCode.F6) then
            self.Enabled = not self.Enabled
            Main:TweenSize(self.Enabled and UDim2.fromOffset(520, 400) or UDim2.fromOffset(520, 0), "Out", "Quart", 0.4, true)
        end
    end)

    local Pages = {}
    local Lib = {}

    function Lib:CreateTab(name)
        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, -20, 1, -20); Page.Position = UDim2.fromOffset(10, 10); Page.BackgroundTransparency = 1; Page.Visible = false; Page.ScrollBarThickness = 0; Page.AutomaticCanvasSize = "Y"
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)
        
        local TabBtn = Instance.new("TextButton", Sidebar)
        TabBtn.Size = UDim2.new(0, 90, 0, 35); TabBtn.BackgroundColor3 = Color3.fromRGB(255, 30, 0); TabBtn.Text = name:upper(); TabBtn.Font = Enum.Font.GothamBold; TabBtn.TextColor3 = Color3.new(1,1,1); TabBtn.TextSize = 12
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 8)
        
        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Pages) do v.Visible = false end
            Page.Visible = true
            TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 100, 100)}):Play()
            task.wait(0.2)
            TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 30, 0)}):Play()
        end)

        if not self.FirstTab then self.FirstTab = Page; Page.Visible = true end
        Pages[name] = Page
        
        local Elements = {}

        function Elements:Toggle(text, default, cb)
            local TFrame = Instance.new("Frame", Page)
            TFrame.Size = UDim2.new(1, 0, 0, 40); TFrame.BackgroundColor3 = Color3.fromRGB(255,255,255); TFrame.BackgroundTransparency = 0.9
            Instance.new("UICorner", TFrame).CornerRadius = UDim.new(0, 8)
            
            local TText = Instance.new("TextLabel", TFrame)
            TText.Size = UDim2.new(1, -60, 1, 0); TText.Position = UDim2.fromOffset(12, 0); TText.Text = text:upper(); TText.Font = Enum.Font.Gotham; TText.TextColor3 = Color3.new(1,1,1); TText.TextSize = 13; TText.BackgroundTransparency = 1; TText.TextXAlignment = 0

            local TToggle = Instance.new("TextButton", TFrame)
            TToggle.Size = UDim2.fromOffset(40, 20); TToggle.Position = UDim2.new(1, -50, 0.5, -10); TToggle.BackgroundColor3 = default and Color3.new(0,1,0) or Color3.new(1,0,0); TToggle.Text = ""
            Instance.new("UICorner", TToggle).CornerRadius = UDim.new(1, 0)

            local state = default
            TToggle.MouseButton1Click:Connect(function()
                state = not state
                TweenService:Create(TToggle, TweenInfo.new(0.3), {BackgroundColor3 = state and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)}):Play()
                cb(state)
            end)
        end

        function Elements:Button(text, cb)
            local B = Instance.new("TextButton", Page)
            B.Size = UDim2.new(1, 0, 0, 38); B.BackgroundColor3 = Color3.fromRGB(255,255,255); B.BackgroundTransparency = 0.8; B.Text = text:upper(); B.Font = Enum.Font.GothamBold; B.TextColor3 = Color3.new(1,1,1); B.TextSize = 13
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)
            B.MouseButton1Click:Connect(cb)
        end

        return Elements
    end
    return Lib
end

return Omni
